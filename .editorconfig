root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[*.{yaml,yml,json,jsonc}]
indent_size = 2

[*.toml]
indent_size = 4

[*.rs]
indent_size = 4

[*.go]
indent_style = tab
indent_size = 4

[*.dart]
indent_size = 2

[*.{js,jsx,ts,tsx,css,scss,html}]
indent_size = 2

[*.{swift,kt,kts,java,c,cc,cpp,h,hpp,m,mm}]
indent_size = 4

[*.{sh,ps1}]
indent_size = 4

[Makefile]
indent_style = tab

[*.csv]
trim_trailing_whitespace = false
