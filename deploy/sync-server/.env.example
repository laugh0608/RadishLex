# Copy this file to deploy/sync-server/.env and replace values before rollout.

COMPOSE_PROJECT_NAME=radishlex-sync

RADISHLEX_SYNC_IMAGE=radishlex-sync-server:dev

# Deployment mode exposes only an HTTP upstream, matching the sibling Radish pattern
# where external Nginx / Traefik / Caddy terminates TLS before forwarding to the app.
RADISHLEX_SYNC_BIND=127.0.0.1
RADISHLEX_SYNC_PORT=7319
RADISHLEX_SYNC_PUBLIC_URL=http://127.0.0.1:7319

# Persistent host directory. Relative paths are resolved from deploy/sync-server/.
# Keep this outside Docker named volumes so SQLite metadata and encrypted blobs
# are easy to inspect and back up.
RADISHLEX_SYNC_DATA_PATH=../../DeployData/SyncServer

RADISHLEX_SYNC_LISTEN=0.0.0.0:7319
RADISHLEX_SYNC_METADATA_PATH=/var/lib/radishlex/sync-server/sync-server.sqlite
RADISHLEX_SYNC_BLOB_DIR=/var/lib/radishlex/sync-server/objects
RADISHLEX_SYNC_MAX_OBJECT_BYTES=16777216
RADISHLEX_SYNC_RECOVERY_READS_PER_HOUR=12
