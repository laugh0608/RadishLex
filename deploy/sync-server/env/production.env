# RadishLex sync server deployment Docker Compose defaults.
# Copy or pass this file with --env-file, then adjust host binding and public URL for the target host.

COMPOSE_PROJECT_NAME=radishlex-sync

RADISHLEX_SYNC_ENV_FILE=./deploy/sync-server/env/production.env
RADISHLEX_SYNC_CADDYFILE=./deploy/sync-server/caddy/production.Caddyfile

# Deployment mode keeps the container entry on HTTP, matching the sibling Radish pattern
# where external Nginx / Traefik / Caddy terminates TLS before forwarding to the app.
RADISHLEX_SYNC_PUBLIC_URL=http://127.0.0.1:7319
RADISHLEX_SYNC_PUBLIC_HOST=127.0.0.1
RADISHLEX_SYNC_PUBLIC_BIND=127.0.0.1
RADISHLEX_SYNC_PUBLIC_PORT=7319
RADISHLEX_SYNC_GATEWAY_PORT=7319

RADISHLEX_SYNC_LISTEN=0.0.0.0:7319
RADISHLEX_SYNC_METADATA_PATH=/var/lib/radishlex/sync-server/sync-server.sqlite
RADISHLEX_SYNC_BLOB_DIR=/var/lib/radishlex/sync-server/objects
RADISHLEX_SYNC_MAX_OBJECT_BYTES=16777216
RADISHLEX_SYNC_RECOVERY_READS_PER_HOUR=12
