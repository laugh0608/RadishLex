# RadishLex sync server local Docker Compose defaults.
# Use with:
#   docker compose --env-file deploy/sync-server/env/local.env up --build

COMPOSE_PROJECT_NAME=radishlex-sync-local

RADISHLEX_SYNC_ENV_FILE=./deploy/sync-server/env/local.env
RADISHLEX_SYNC_CADDYFILE=./deploy/sync-server/caddy/local.Caddyfile

# Local container verification keeps the public entry on HTTPS.
RADISHLEX_SYNC_PUBLIC_URL=https://localhost:7443
RADISHLEX_SYNC_PUBLIC_HOST=localhost
RADISHLEX_SYNC_PUBLIC_BIND=127.0.0.1
RADISHLEX_SYNC_PUBLIC_PORT=7443
RADISHLEX_SYNC_GATEWAY_PORT=7443

RADISHLEX_SYNC_LISTEN=0.0.0.0:7319
RADISHLEX_SYNC_METADATA_PATH=/var/lib/radishlex/sync-server/sync-server.sqlite
RADISHLEX_SYNC_BLOB_DIR=/var/lib/radishlex/sync-server/objects
RADISHLEX_SYNC_MAX_OBJECT_BYTES=16777216
RADISHLEX_SYNC_RECOVERY_READS_PER_HOUR=12
